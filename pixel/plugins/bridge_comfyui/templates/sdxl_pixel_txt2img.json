{
  "id": "sdxl_pixel_txt2img",
  "name": "SDXL + Pixel Art LoRA (txt2img)",
  "mode": "txt2img",
  "requirements": {
    "checkpoint": "sd_xl_base_1.0.safetensors",
    "checkpoint_source": "https://huggingface.co/stabilityai/stable-diffusion-xl-base-1.0",
    "lora": "pixel-art-xl.safetensors (user supplied; verify its license)",
    "lora_discovery": "https://civitai.com/search/models?query=pixel%20art%20xl"
  },
  "bindings": {
    "prompt": "6.inputs.text",
    "negative_prompt": "7.inputs.text",
    "seed": "3.inputs.seed",
    "width": "5.inputs.width",
    "height": "5.inputs.height",
    "batch": "5.inputs.batch_size",
    "lora": "10.inputs.lora_name"
  },
  "workflow": {
    "3": {"class_type": "KSampler", "inputs": {"seed": 1, "steps": 24, "cfg": 7.0, "sampler_name": "euler", "scheduler": "normal", "denoise": 1.0, "model": ["10", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0]}},
    "4": {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "sd_xl_base_1.0.safetensors"}},
    "5": {"class_type": "EmptyLatentImage", "inputs": {"width": 1024, "height": 1024, "batch_size": 1}},
    "6": {"class_type": "CLIPTextEncode", "inputs": {"text": "pixel art sprite", "clip": ["10", 1]}},
    "7": {"class_type": "CLIPTextEncode", "inputs": {"text": "blurry, antialiasing", "clip": ["10", 1]}},
    "8": {"class_type": "VAEDecode", "inputs": {"samples": ["3", 0], "vae": ["4", 2]}},
    "9": {"class_type": "SaveImage", "inputs": {"filename_prefix": "PixelForge", "images": ["8", 0]}},
    "10": {"class_type": "LoraLoader", "inputs": {"lora_name": "pixel-art-xl.safetensors", "strength_model": 1.0, "strength_clip": 1.0, "model": ["4", 0], "clip": ["4", 1]}}
  }
}
