+       "segment_params":
+       {
+           "merge_distance":
+           int(Dictionary(params.get("segment_params", {})).get("merge_distance", 2)),
+           "min_area": int(Dictionary(params.get("segment_params", {})).get("min_area", 4)),
+       },
