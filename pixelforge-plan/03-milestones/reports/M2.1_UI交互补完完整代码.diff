+           Vector2(PADDING, 21),
+           "%s (%d)" % [label, asset_ids.size()],
+           HORIZONTAL_ALIGNMENT_LEFT,
+           CARD_WIDTH - PADDING * 2,
+           13,
+           Color(0.9, 0.92, 0.92, 1.0)
+       )
