+   return {
+       "mode": String(params.get("mode", Matting.MODE_FLOOD)),
+       "tolerance": float(params.get("tolerance", 12.0)),
+       "feather": int(params.get("feather", 0)),
+   }
+
+
+func _slice_params(params: Dictionary) -> Dictionary:
+   if params.is_empty():
