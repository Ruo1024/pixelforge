+func _start_batch_task(
+   card_id: String,
+   asset_ids: Array,
+   task_kind: String,
+   extra: Dictionary,
+   work: Callable,
+   queued_status: String,
+   done_status: String
+) -> void:
+   var ids := _string_array(asset_ids)
